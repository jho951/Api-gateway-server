# Local development profile (copy and update as needed)
GATEWAY_BIND=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_REQUEST_TIMEOUT_MS=30000
GATEWAY_AUTH_TIMEOUT_MS=3000
GATEWAY_AUTH_CACHE_TTL_SECONDS=15
GATEWAY_LOGIN_RATE_LIMIT_PER_MINUTE=20
GATEWAY_MAX_BODY_BYTES=1048576
GATEWAY_CORS_ALLOWED_ORIGINS=*
GATEWAY_IP_GUARD_ENABLED=false
GATEWAY_ALLOWED_IPS=127.0.0.1
GATEWAY_IP_GUARD_DEFAULT_ALLOW=true
GATEWAY_ADMIN_IP_GUARD_ENABLED=true
GATEWAY_ADMIN_ALLOWED_IPS=127.0.0.1,192.168.65.1
GATEWAY_ADMIN_IP_GUARD_DEFAULT_ALLOW=false
GATEWAY_ADVANCED_ROUTE_POLICIES_ENABLED=false
GATEWAY_PERMISSION_CACHE_ENABLED=false
GATEWAY_PERMISSION_CACHE_TTL_SECONDS=300
GATEWAY_PERMISSION_CACHE_PREFIX=gateway:admin-permission:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_TIMEOUT_MS=1000
AUTH_SERVICE_URL=http://localhost:8081
USER_SERVICE_URL=http://localhost:8082
BLOCK_SERVICE_URL=http://localhost:8083
PERMISSION_SERVICE_URL=http://localhost:8084
AUTH_VALIDATE_URL=http://localhost:8081/auth/internal/session/validate

# JWT verification helpers
# Set AUTH_JWT_VERIFY_ENABLED=true and provide AUTH_JWT_PUBLIC_KEY_PEM if you want
# gateway-side validation of auth-service tokens. Multi-line PEM can be encoded as
# a quoted string with literal newlines (\\n).
AUTH_JWT_VERIFY_ENABLED=false
AUTH_JWT_PUBLIC_KEY_PEM=
AUTH_JWT_KEY_ID=
AUTH_JWT_ALGORITHM=RS256
AUTH_JWT_ISSUER=https://auth.example.com
AUTH_JWT_AUDIENCE=api-gateway
AUTH_JWT_CLOCK_SKEW_SECONDS=30
