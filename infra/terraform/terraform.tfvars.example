aws_region   = "ap-northeast-2"
project_name = "msa"
environment  = "prod"

service_name         = "gateway-service"
service_runtime_name = "gateway"
service_role         = "gateway-service"

create_vpc = false

existing_vpc_id             = "vpc-0123456789abcdef0"
existing_public_subnet_ids  = ["subnet-0publica123456789", "subnet-0publicc123456789"]
existing_private_subnet_ids = ["subnet-0appa1234567890", "subnet-0appc1234567890"]
existing_vpc_cidr           = "10.0.0.0/16"

alb_internal               = false
app_ingress_cidrs          = ["0.0.0.0/0"]
test_listener_ingress_cidrs = ["10.0.0.0/16"]
app_port      = 8080
desired_count = 2
task_cpu      = 512
task_memory   = 1024

health_check_path = "/health"

image_tag    = "latest"
enable_mysql = false

app_env = {
  APP_ENV                 = "prod"
  APP_ENV_FILE            = "/app/.env.prod"
  GATEWAY_BIND            = "0.0.0.0"
  GATEWAY_PORT            = "8080"
  AUTH_SERVICE_URL        = "http://auth.internal.platform.local"
  AUTH_SERVICE_INTERNAL_REQUEST_SECRET = "replace-with-auth-service-internal-secret"
  USER_SERVICE_URL        = "http://user.internal.platform.local"
  EDITOR_SERVICE_URL      = "http://editor.internal.platform.local"
  AUTHZ_ADMIN_VERIFY_URL = "http://authz.internal.platform.local/permissions/internal/admin/verify"
  AUTHZ_INTERNAL_JWT_ISSUER = "api-gateway"
  AUTHZ_INTERNAL_JWT_AUDIENCE = "authz-service"
  REDIS_HOST              = "redis.internal.platform.local"
  REDIS_PORT              = "6379"
  REDIS_TIMEOUT_MS        = "1000"
  GATEWAY_AUTHZ_CACHE_ENABLED                = "false"
  GATEWAY_AUTHZ_CACHE_TTL_SECONDS            = "300"
  GATEWAY_AUTHZ_CACHE_PREFIX                 = "gateway:admin-authz:"
  GATEWAY_SESSION_CACHE_ENABLED              = "true"
  GATEWAY_SESSION_LOCAL_CACHE_TTL_SECONDS    = "3"
  GATEWAY_SESSION_CACHE_TTL_SECONDS          = "60"
  GATEWAY_SESSION_CACHE_KEY_PREFIX           = "gateway:session:"
}

app_secret_env = {
  GATEWAY_INTERNAL_REQUEST_SECRET = "replace-with-shared-internal-secret"
  AUTHZ_INTERNAL_JWT_SECRET = "replace-with-authz-internal-jwt-secret"
}
